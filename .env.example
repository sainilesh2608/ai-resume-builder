# ━━━━━ BACKEND (Server-side, NEVER exposed to browser) ━━━━━
# Google Generative Language API key - get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# Server port (optional, defaults to 5000)
PORT=5000

# ━━━━━ FRONTEND (Client-side, for production deployments) ━━━━━
# In development: leave empty (Vite proxy will forward /api to localhost:5000)
# In production: set to your backend URL, e.g., https://your-app.onrender.com
VITE_API_BASE=
